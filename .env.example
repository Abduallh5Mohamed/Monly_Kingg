# Environment Configuration Template
# ⚠️ SECURITY: This is a template. Copy to .env and fill with real values
# NEVER commit .env to git!

PORT=5000
NODE_ENV=development

# ✅ SECURITY: Data Encryption Key (NEW - REQUIRED)
# CRITICAL: Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# This key encrypts sensitive data like phone numbers, email addresses, names
ENCRYPTION_KEY=REPLACE_WITH_64_CHARACTER_HEX_KEY

# Database Configuration
# SECURITY: Use strong credentials in production
MONGO_URI=mongodb://username:password@localhost:27017/accountsstore

# JWT Configuration
# CRITICAL SECURITY: Generate strong random secret (64+ characters)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=REPLACE_WITH_STRONG_RANDOM_SECRET_MINIMUM_64_CHARACTERS
# OTP Security - REQUIRED separate secret for HMAC-based OTP hashing
# CRITICAL: Must be different from JWT_SECRET. Server will refuse to start without it.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
OTP_SECRET=REPLACE_WITH_STRONG_RANDOM_OTP_SECRET_64_CHARS
JWT_ACCESS_EXPIRES=15m
REFRESH_TOKEN_EXPIRES_DAYS=30
BCRYPT_SALT_ROUNDS=12

# IP Anonymization — salt used for hashing IPs before storage
# Generate: node -e "console.log(require('crypto').randomBytes(16).toString('hex'))"
IP_SALT=REPLACE_WITH_RANDOM_IP_SALT

# Redis Configuration
# SECURITY: Use strong password (64+ characters recommended)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=REPLACE_WITH_STRONG_RANDOM_PASSWORD_MINIMUM_64_CHARACTERS
REDIS_DB=0

# Email Configuration
# Use app-specific password, NOT your main email password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-specific-password
EMAIL_FROM="MonlyKing <noreply@yourdomain.com>"

# Frontend URL
FRONTEND_URL=http://localhost:3000

# Security - Cookie Names
ACCESS_TOKEN_COOKIE_NAME=access_token
REFRESH_TOKEN_COOKIE_NAME=refresh_token
CSRF_COOKIE_NAME=xsrf_token

# Production Settings (uncomment for production)
# ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
# PROXY_HOPS=1
# HEALTH_ENDPOINT_TOKEN=REPLACE_WITH_STRONG_RANDOM_MONITORING_TOKEN

# ========================================
# 🚨 CRITICAL SECURITY WARNINGS:
# ========================================
# 1. NEVER commit .env to git (check .gitignore)
# 2. Generate strong random secrets:
#    node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# 3. Use different secrets for dev/staging/production
# 4. Rotate secrets regularly (every 90 days minimum)
# 5. Use secrets manager in production (AWS Secrets Manager, Azure Key Vault)
# 6. Keep .env file permissions restricted (chmod 600)
# 7. Never share secrets via email/chat
# 8. Revoke and regenerate if exposed
# ========================================
# Google OAuth (for Continue with Google)
# ========================================
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_CALLBACK_URL=http://localhost:5000/api/v1/auth/google/callback
